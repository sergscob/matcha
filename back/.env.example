NODE_ENV=development

PORT=3000

DATABASE_URL=postgres://matcha:matcha@localhost:5432/matcha

JWT_SECRET=super-secret-key

# Set to "true" only when the app is actually served over HTTPS - the
# httpOnly auth cookie won't be sent by the browser over plain HTTP otherwise.
COOKIE_SECURE=false

CORS_ORIGIN=http://localhost:5173

FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Matcha <no-reply@matcha.local>
